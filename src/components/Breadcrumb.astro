---
import { House } from "@lucide/astro";
import { useTranslations } from "../utils/i18n";

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  lang: string;
  items: BreadcrumbItem[];
}

const { lang, items } = Astro.props;
const t = useTranslations(lang);
---

<nav aria-label={t("a11y.breadcrumb")} class="mb-4 flex items-center gap-2 text-sm">
  <a
    href={`/${lang}/`}
    class="text-muted hover:text-primary-light flex items-center gap-1.5 transition-colors"
  >
    <House size={14} />
    <span>{t("nav.home")}</span>
  </a>
  {
    items.map((item) => (
      <>
        <span class="text-muted">/</span>
        <a href={item.href} class="text-muted hover:text-primary-light transition-colors">
          {item.label}
        </a>
      </>
    ))
  }
</nav>
