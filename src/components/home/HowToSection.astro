---
import {
  ArrowRight,
  BookOpen,
  Clock,
  Languages,
  MessageCirclePlus,
  Search,
  Star,
} from "@lucide/astro";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === "en" ? "/en" : "/es";

const steps = [
  {
    num: 1,
    icon: Search,
    titleKey: "home.howto.step1.title",
    descKey: "home.howto.step1.description",
    href: `${prefix}/buscar/`,
  },
  {
    num: 2,
    icon: Star,
    titleKey: "home.howto.step2.title",
    descKey: "home.howto.step2.description",
    href: `${prefix}/#featured-words`,
  },
  {
    num: 3,
    icon: Clock,
    titleKey: "home.howto.step3.title",
    descKey: "home.howto.step3.description",
    href: `${prefix}/#latest-words`,
  },
  {
    num: 4,
    icon: BookOpen,
    titleKey: "home.howto.step4.title",
    descKey: "home.howto.step4.description",
    href: `${prefix}/indice/`,
  },
  {
    num: 5,
    icon: Languages,
    titleKey: "home.howto.step5.title",
    descKey: "home.howto.step5.description",
    href: `${prefix}/#header`,
  },
  {
    num: 6,
    icon: MessageCirclePlus,
    titleKey: "home.howto.step6.title",
    descKey: "home.howto.step6.description",
    href: `${prefix}/contribuir/`,
  },
];
---

<section id="how-to" class="mx-auto max-w-275 px-6 py-6">
  <div class="mx-auto max-w-full">
    <div class="grid gap-6 md:grid-cols-2">
      {
        steps.map((step) => (
          <div class="border-theme bg-card group shadow-theme-sm hover:border-primary/30 hover:shadow-theme-md focus-within:ring-primary/50 rounded-xl border p-6 transition-all duration-300 focus-within:ring-2">
            <div class="mb-4 flex items-center gap-4">
              <div class="bg-primary/10 group-hover:bg-primary/15 relative flex size-12 shrink-0 items-center justify-center rounded-lg transition-colors duration-300">
                <step.icon class="text-primary-light" size="24" />
                <span class="bg-primary absolute -top-1.5 -right-1.5 flex size-5 items-center justify-center rounded-full text-[10px] leading-none font-bold text-white">
                  {step.num}
                </span>
              </div>
              <div class="pt-0.5">
                <h2 class="font-title text-theme text-2xl">{t(step.titleKey)}</h2>
              </div>
            </div>
            <p class="text-muted text-base leading-relaxed" set:html={t(step.descKey)} />
            <div class="border-theme my-5 border-t" />
            <a
              href={step.href}
              class="text-primary-light border-theme bg-card hover:bg-card-hover hover:border-primary/40 focus-visible:outline-primary inline-flex items-center gap-2 rounded-md border px-3 py-1.5 text-sm font-semibold transition-all duration-200 focus-visible:outline-2 focus-visible:outline-offset-2"
            >
              <span>{t(step.titleKey)}</span>
              <ArrowRight size={14} />
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
