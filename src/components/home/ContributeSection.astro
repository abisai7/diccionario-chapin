---
import { ExternalLink, HeartHandshake, Link, MessageCirclePlus } from "@lucide/astro";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === "en" ? "/en" : "/es";
---

<section class="mx-auto max-w-275 px-6 pb-12">
  <div class="border-theme bg-card shadow-theme-md mt-8 rounded-2xl border p-6">
    <h2 class="m-0 mb-3 flex items-center gap-2 text-xl font-semibold">
      <HeartHandshake class="text-primary-light" size={20} />
      {t("home.contribute.title")}
    </h2>
    <p class="text-secondary mb-4 text-sm leading-relaxed">
      {t("home.contribute.subtitle")}
    </p>
    <div class="grid gap-4 md:grid-cols-2">
      <div class="border-theme bg-accent rounded-md border p-4">
        <h3 class="m-0 mb-2 flex items-center gap-2 text-base font-semibold">
          <MessageCirclePlus class="text-primary-light" size={20} />
          {t("home.contribute.all.title")}
        </h3>
        <p class="text-muted mb-3 text-sm leading-relaxed">
          {t("home.contribute.all.description")}
        </p>
        <a
          href={`${prefix}/contribuir/`}
          class="cta-primary-gradient focus-visible:outline-primary inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 active:scale-95"
          data-umami-event="Contribute Non Technical Click"
          data-umami-event-type="non-technical"
        >
          <Link size={14} />
          <span class="mt-0.5">{t("home.contribute.all.button")}</span>
        </a>
      </div>
      <div class="border-theme bg-accent rounded-md border p-4">
        <h3 class="m-0 mb-2 flex items-center gap-2 text-base font-semibold">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary-light"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path>
          </svg>
          {t("home.contribute.tech.title")}
        </h3>
        <p class="text-muted mb-3 text-sm leading-relaxed">
          {t("home.contribute.tech.description")}
        </p>
        <a
          href="https://github.com/abisai7/diccionario-chapin"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-light inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
          data-umami-event="Contribute GitHub Click"
          data-umami-event-type="technical"
        >
          <span class="mt-1">{t("home.contribute.tech.button")}</span>
          <ExternalLink size={16} />
        </a>
      </div>
    </div>
  </div>
</section>
