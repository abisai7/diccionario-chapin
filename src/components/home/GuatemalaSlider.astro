---
export interface Image {
  url: string;
  alt: string;
  photographer: string;
  photographerUrl: string;
}

export interface Props {
  images?: Image[];
}

const { images = [] }: Props = Astro.props;

if (images.length === 0) {
  return null;
}
---

<section class="mx-auto max-w-275 px-6 py-4">
  <div class="guatemala-slider-container relative overflow-hidden rounded-2xl">
    <div class="guatemala-slider-fade-left"></div>
    <div class="guatemala-slider-fade-right"></div>
    <div class="guatemala-slider-track">
      {
        [...images, ...images].map((img) => (
          <div class="guatemala-slider-slide">
            <img
              src={img.url}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              class="guatemala-slider-img"
            />
            <div class="guatemala-slider-attribution">
              Photo by{" "}
              <a
                href={`${img.photographerUrl}?utm_source=chapinismos.org&utm_medium=referral`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {img.photographer}
              </a>{" "}
              on{" "}
              <a
                href="https://unsplash.com/?utm_source=chapinismos.org&utm_medium=referral"
                target="_blank"
                rel="noopener noreferrer"
              >
                Unsplash
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .guatemala-slider-container {
    background: var(--card);
    border: 1px solid var(--border);
    padding: 0.75rem;
  }

  .guatemala-slider-track {
    display: flex;
    gap: 1rem;
    animation: sliderScroll 100s linear infinite;
    width: max-content;
  }

  .guatemala-slider-container:hover .guatemala-slider-track {
    animation-play-state: paused;
  }

  .guatemala-slider-slide {
    position: relative;
    flex-shrink: 0;
    border-radius: 12px;
    overflow: hidden;
    height: 280px;
    width: 400px;
  }

  .guatemala-slider-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .guatemala-slider-slide:hover .guatemala-slider-img {
    transform: scale(1.05);
  }

  .guatemala-slider-attribution {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 0.75rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .guatemala-slider-attribution a {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.2s;
  }

  .guatemala-slider-attribution a:hover {
    color: #fff;
  }

  .guatemala-slider-fade-left,
  .guatemala-slider-fade-right {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 10;
    pointer-events: none;
  }

  .guatemala-slider-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--card) 0%, transparent 100%);
  }

  .guatemala-slider-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--card) 0%, transparent 100%);
  }

  @keyframes sliderScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .guatemala-slider-track {
      animation: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    .guatemala-slider-slide {
      scroll-snap-align: start;
    }
  }

  @media (max-width: 768px) {
    .guatemala-slider-slide {
      height: 200px;
      width: 280px;
    }

    .guatemala-slider-fade-left,
    .guatemala-slider-fade-right {
      width: 40px;
    }
  }

  @media (max-width: 480px) {
    .guatemala-slider-slide {
      height: 160px;
      width: 240px;
    }
  }
</style>
