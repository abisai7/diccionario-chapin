---
import SearchBox from "../SearchBox.astro";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang: string;
  standalone?: boolean;
}

const { lang, standalone = true } = Astro.props;
const t = useTranslations(lang);

const cardClasses = [
  "card-with-gradient shadow-theme-lg grid gap-4 backdrop-blur-sm",
  standalone && "m-6",
]
  .filter(Boolean)
  .join(" ");
---

{
  standalone ? (
    <section class="mx-auto max-w-[1100px]">
      <div class={cardClasses}>
        <h1 class="gradient-text mx-4 mt-4 text-[clamp(1.8rem,2.4vw,2.6rem)]">{t("home.title")}</h1>
        <p class="text-muted mx-4 text-base">{t("home.subtitle")}</p>
        <div class="mx-4 mb-4 grid grid-cols-1">
          <SearchBox placeholder={t("home.search.placeholder")} />
        </div>
      </div>
    </section>
  ) : (
    <div class={cardClasses}>
      <h1 class="gradient-text mx-4 mt-4 text-[clamp(1.8rem,2.4vw,2.6rem)]">{t("home.title")}</h1>
      <p class="text-muted mx-4 text-base">{t("home.subtitle")}</p>
      <div class="mx-4 mb-4 grid grid-cols-1">
        <SearchBox placeholder={t("home.search.placeholder")} />
      </div>
    </div>
  )
}
