---
import type { CollectionEntry } from "astro:content";
import SearchBox from "../SearchBox.astro";
import { useTranslations } from "../../utils/i18n";

interface Props {
  lang: string;
  standalone?: boolean;
  popularWords?: CollectionEntry<"words-es" | "words-en">[];
  allWordIds?: string[];
}

const { lang, standalone = true, popularWords = [], allWordIds = [] } = Astro.props;
const t = useTranslations(lang);

const cardClasses = [
  "card-with-gradient shadow-theme-lg grid gap-4 backdrop-blur-sm",
  standalone && "m-6",
]
  .filter(Boolean)
  .join(" ");

const pillClasses =
  "inline-block rounded-full border px-3 py-1 text-xs font-medium transition bg-card border-theme text-secondary hover:border-[var(--primary)] hover:text-theme";

const randomPillClasses =
  "inline-block rounded-full border px-3 py-1 text-xs font-medium transition bg-glow-primary border-[var(--primary)] text-primary hover:bg-[var(--primary)] hover:text-white";
---

{
  standalone ? (
    <section class="mx-auto max-w-[1100px]">
      <div class={cardClasses}>
        <h1 class="gradient-text mx-4 mt-4 text-[clamp(1.8rem,2.4vw,2.6rem)]">{t("home.title")}</h1>
        <p class="text-muted mx-4 text-base">{t("home.subtitle")}</p>
        <div class="mx-4 mb-4 grid grid-cols-1">
          <SearchBox placeholder={t("home.search.placeholder")} />
          {popularWords.length > 0 && (
            <div
              id="popular-pills"
              class="mt-3 flex flex-wrap gap-2"
              data-ids={JSON.stringify(allWordIds)}
              data-lang={lang}
            >
              {popularWords.map((entry) => (
                <a href={`/${lang}/palabras/${entry.id}/`} class={pillClasses}>
                  {entry.data.word}
                </a>
              ))}
              <button id="random-word-btn" type="button" class={randomPillClasses}>
                {t("home.randomWord")}
              </button>
            </div>
          )}
        </div>
      </div>
    </section>
  ) : (
    <div class={cardClasses}>
      <h1 class="gradient-text mx-4 mt-4 text-[clamp(1.8rem,2.4vw,2.6rem)]">{t("home.title")}</h1>
      <p class="text-muted mx-4 text-base">{t("home.subtitle")}</p>
      <div class="mx-4 mb-4 grid grid-cols-1">
        <SearchBox placeholder={t("home.search.placeholder")} />
        {popularWords.length > 0 && (
          <div
            id="popular-pills"
            class="mt-3 flex flex-wrap gap-2"
            data-ids={JSON.stringify(allWordIds)}
            data-lang={lang}
          >
            {popularWords.map((entry) => (
              <a href={`/${lang}/palabras/${entry.id}/`} class={pillClasses}>
                {entry.data.word}
              </a>
            ))}
            <button id="random-word-btn" type="button" class={randomPillClasses}>
              {t("home.randomWord")}
            </button>
          </div>
        )}
      </div>
    </div>
  )
}

<script>
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("random-word-btn");
    const pills = document.getElementById("popular-pills");
    if (!btn || !pills) return;

    btn.addEventListener("click", () => {
      const ids: string[] = JSON.parse(pills.dataset.ids || "[]");
      const lang = pills.dataset.lang || "es";
      if (ids.length === 0) return;
      const randomId = ids[Math.floor(Math.random() * ids.length)];
      window.location.href = `/${lang}/palabras/${randomId}/`;
    });
  });
</script>
