---
import { CircleHelp } from "@lucide/astro";
import { getLangFromUrl, useTranslations } from "../utils/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === "en" ? "/en" : "/es";
---

<!-- Navegación desktop -->
<a
  href={`${prefix}/`}
  class="nav-link px-3 py-2"
  data-umami-event="Nav Home"
  data-umami-event-device="desktop"
>
  {t("nav.home")}
</a>
<a
  href={`${prefix}/indice/`}
  class="nav-link px-3 py-2"
  data-umami-event="Nav Index"
  data-umami-event-device="desktop"
>
  {t("nav.index")}
</a>
<a
  href={`${prefix}/buscar/`}
  class="nav-link px-3 py-2"
  data-umami-event="Nav Search"
  data-umami-event-device="desktop"
>
  {t("nav.search")}
</a>
<a
  href={`${prefix}/contribuir/`}
  class="nav-link px-3 py-2"
  data-umami-event="Nav Contribute"
  data-umami-event-device="desktop"
>
  {t("nav.contribute")}
</a>
<a
  href={`${prefix}/ayuda/`}
  class="nav-link flex items-center justify-center px-3 py-2"
  aria-label={t("nav.help")}
  data-umami-event="Nav Help"
  data-umami-event-device="desktop"
>
  <CircleHelp size="20" />
</a>
