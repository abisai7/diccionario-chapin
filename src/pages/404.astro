---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Página no encontrada | Chapinismos</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#4997D0" />
    <ClientRouter fallback="none" />
  </head>
  <body class="bg-body text-theme flex min-h-screen flex-col items-center justify-center px-6">
    <div class="text-center">
      <p class="text-primary mb-2 text-6xl font-bold opacity-80">404</p>
      <h1
        class="mb-4 bg-linear-to-r bg-clip-text text-4xl font-bold text-transparent sm:text-5xl"
        style="background-image: linear-gradient(135deg, var(--primary-light) 0%, var(--primary) 50%, #9333ea 100%)"
      >
        ¡Aguas!
      </h1>
      <p class="text-secondary mb-8 max-w-md text-lg">
        Esta página no existe, patojo (a). Puede que el enlace esté roto o la dirección haya
        cambiado.
      </p>
      <p class="text-muted mb-8 text-sm italic">
        This page doesn't exist. The link might be broken or the address may have changed.
      </p>
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/es/"
          class="badge-primary-gradient hover:shadow-theme-lg inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 active:scale-95"
        >
          🇬🇹 Ir al inicio (ES)
        </a>
        <a
          href="/en/"
          class="border-theme bg-card hover:shadow-theme-md inline-flex items-center gap-2 rounded-lg border px-6 py-3 text-sm font-semibold transition-all duration-200 hover:-translate-y-0.5 active:scale-95"
        >
          🇺🇸 Go to home (EN)
        </a>
      </div>
    </div>
  </body>
</html>
