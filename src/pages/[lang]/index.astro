---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import Ticker from "../../components/Ticker.astro";
import HeroSection from "../../components/home/HeroSection.astro";
import AboutSection from "../../components/home/AboutSection.astro";
import DailyWord from "../../components/home/DailyWord.astro";
import FeaturedWords from "../../components/home/FeaturedWords.astro";
import LatestWords from "../../components/home/LatestWords.astro";
import GuatemalaSlider from "../../components/home/GuatemalaSlider.astro";
import ContributeSection from "../../components/home/ContributeSection.astro";
import BreadcrumbSchema from "../../components/schemas/BreadcrumbSchema.astro";
import FeaturedWordsSchema from "../../components/schemas/FeaturedWordsSchema.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "../../utils/i18n";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const collectionName = lang === "es" ? "words-es" : "words-en";
const allWords = await getCollection(collectionName);

// Hreflang URLs for multilingual SEO
const alternateUrls = {
  es: "/es/",
  en: "/en/",
  xDefault: "/es/", // Default to Spanish
};
const wordList = allWords.map((w) => w.data.word);
const shuffled = [...wordList].sort(() => Math.random() - 0.5);
const featured = shuffled.slice(0, Math.min(45, shuffled.length));

const FEATURED_WORDS_COUNT = 6;
const LATEST_WORDS_COUNT = 6;

// Get featured words or fallback to random if none are marked
const featuredWords = allWords.filter((w) => w.data.featured === true);
const top =
  featuredWords.length >= FEATURED_WORDS_COUNT
    ? featuredWords.slice(0, FEATURED_WORDS_COUNT)
    : [...allWords].sort(() => Math.random() - 0.5).slice(0, FEATURED_WORDS_COUNT);

const latestWords = [...allWords]
  .sort(
    (a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime()
  )
  .slice(0, LATEST_WORDS_COUNT);

const siteUrl = Astro.site || "https://chapinismos.org";

// Fetch Guatemala photos from Unsplash at build time
let guatemalaImages: { url: string; alt: string; photographer: string; photographerUrl: string }[] =
  [];
const unsplashKey = import.meta.env.UNSPLASH_ACCESS_KEY;
if (unsplashKey) {
  try {
    const res = await fetch(
      `https://api.unsplash.com/search/photos?query=guatemala&per_page=10&orientation=landscape&client_id=${unsplashKey}`
    );
    if (res.ok) {
      const data = await res.json();
      guatemalaImages = (data.results || []).map((img: any) => ({
        url: img.urls?.regular || img.urls?.small || "",
        alt: img.alt_description || "Guatemala photo",
        photographer: img.user?.name || "Unknown",
        photographerUrl: img.user?.links?.html || "#",
      }));
    }
  } catch {
    // Graceful fallback: render nothing if API fails
  }
}
---

<Base
  title={t("home.title")}
  description={t("home.description")}
  keywords={t("home.keywords")}
  lang={lang}
  alternateUrls={alternateUrls}
>
  <BreadcrumbSchema slot="schema" lang={lang} siteUrl={siteUrl} items={[]} />
  <FeaturedWordsSchema slot="schema" lang={lang} siteUrl={siteUrl} words={top} />

  <HeroSection lang={lang} />

  <div class="mx-auto mb-6 grid max-w-275 grid-cols-1 gap-6 px-6 lg:grid-cols-[5fr_2fr]">
    <div
      class="card-with-gradient flex flex-col p-6 [&_section]:mx-0 [&_section]:max-w-none [&_section]:px-0 [&_section:last-child]:mb-0"
    >
      <FeaturedWords words={top} lang={lang} />
      <LatestWords words={latestWords} lang={lang} />
    </div>
    <DailyWord words={allWords} lang={lang} standalone={false} />
  </div>

  {guatemalaImages.length > 0 && <GuatemalaSlider images={guatemalaImages} />}

  <AboutSection lang={lang} />

  <section class="mx-auto max-w-275 px-6">
    <Ticker words={featured} lang={lang} variant="vibrant" rows={1} />
  </section>

  <ContributeSection lang={lang} />
</Base>
