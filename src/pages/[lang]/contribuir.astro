---
export const prerender = true;

import Base from "../../layouts/Base.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BreadcrumbSchema from "../../components/schemas/BreadcrumbSchema.astro";
import { useTranslations } from "../../utils/i18n";
import { Send } from "@lucide/astro";
import { Info } from "@lucide/astro";
import { Check } from "@lucide/astro";
import { BookOpen } from "@lucide/astro";
import { Plus } from "@lucide/astro";

export async function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const prefix = lang === "en" ? "/en" : "/es";

const alternateUrls = {
  es: "/es/contribuir/",
  en: "/en/contribuir/",
  xDefault: "/es/contribuir/",
};

const siteUrl = Astro.site || "https://chapinismos.org";
---

<Base
  title={`${t("contribute.page.title")} | ${t("schema.site.name")}`}
  description={t("contribute.page.description")}
  keywords={t("contribute.page.keywords")}
  lang={lang}
  alternateUrls={alternateUrls}
>
  <BreadcrumbSchema
    slot="schema"
    lang={lang}
    siteUrl={siteUrl}
    items={[{ name: t("contribute.page.title"), url: `/${lang}/contribuir/` }]}
  />

  <section class="mx-auto max-w-230 px-6 pb-14">
    <Breadcrumb
      lang={lang}
      items={[{ label: t("contribute.page.title"), href: `/${lang}/contribuir/` }]}
    />
    <div class="border-theme bg-card shadow-theme-md mt-6 rounded-2xl border p-6 md:p-8">
      <h1 class="gradient-text m-0 text-[clamp(1.8rem,2.4vw,2.6rem)]" style="text-wrap: balance;">
        {t("contribute.page.title")}
      </h1>
      <p class="text-secondary mt-3 mb-7 text-base leading-relaxed">
        {t("contribute.page.description")}
      </p>

      <form
        id="contributeForm"
        class="grid gap-5"
        novalidate
        aria-describedby="contributeFormIntro"
      >
        <div hidden>
          <label for="company">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
        </div>

        <div class="grid gap-2">
          <label class="text-theme text-sm font-semibold" for="word">
            {t("contribute.form.word.label")}
            <span class="text-error ms-1" aria-hidden="true">*</span>
          </label>
          <input
            id="word"
            name="word"
            type="text"
            required
            maxlength="80"
            autocomplete="off"
            aria-required="true"
            aria-describedby="wordHint wordError"
            class="border-theme bg-accent text-theme focus:border-primary rounded-lg border px-3 py-2.5 transition-colors focus:outline-hidden"
            placeholder={t("contribute.form.word.placeholder")}
          />
          <div class="flex items-center justify-between gap-3">
            <p id="wordHint" class="text-secondary m-0 inline-flex items-start gap-2 text-sm">
              <Info size={14} class="mt-0.5 shrink-0" aria-hidden="true" />
              <span>{t("contribute.form.word.hint")}</span>
            </p>
            <span id="wordCount" class="text-muted shrink-0 text-xs tabular-nums" aria-live="polite"
              >0/80</span
            >
          </div>
          <p id="wordError" class="text-error m-0 hidden text-sm" role="alert"></p>
        </div>

        <div class="grid gap-2">
          <label class="text-theme text-sm font-semibold" for="meaning">
            {t("contribute.form.meaning.label")}
          </label>
          <textarea
            id="meaning"
            name="meaning"
            rows="4"
            maxlength="1200"
            aria-describedby="meaningHint meaningError"
            class="border-theme bg-accent text-theme focus:border-primary rounded-lg border px-3 py-2.5 transition-colors focus:outline-hidden"
            placeholder={t("contribute.form.meaning.placeholder")}></textarea>
          <div class="flex items-center justify-between gap-3">
            <p id="meaningHint" class="text-secondary m-0 inline-flex items-start gap-2 text-sm">
              <Info size={14} class="mt-0.5 shrink-0" aria-hidden="true" />
              <span>{t("contribute.form.meaning.hint")}</span>
            </p>
            <span
              id="meaningCount"
              class="text-muted shrink-0 text-xs tabular-nums"
              aria-live="polite">0/1200</span
            >
          </div>
          <p id="meaningError" class="text-error m-0 hidden text-sm" role="alert"></p>
        </div>

        <div class="grid gap-2">
          <label class="text-theme text-sm font-semibold" for="examples">
            {t("contribute.form.examples.label")}
          </label>
          <textarea
            id="examples"
            name="examples"
            rows="4"
            maxlength="1200"
            aria-describedby="examplesHint examplesError"
            class="border-theme bg-accent text-theme focus:border-primary rounded-lg border px-3 py-2.5 transition-colors focus:outline-hidden"
            placeholder={t("contribute.form.examples.placeholder")}></textarea>
          <div class="flex items-center justify-between gap-3">
            <p id="examplesHint" class="text-secondary m-0 inline-flex items-start gap-2 text-sm">
              <Info size={14} class="mt-0.5 shrink-0" aria-hidden="true" />
              <span>{t("contribute.form.examples.hint")}</span>
            </p>
            <span
              id="examplesCount"
              class="text-muted shrink-0 text-xs tabular-nums"
              aria-live="polite">0/1200</span
            >
          </div>
          <p id="examplesError" class="text-error m-0 hidden text-sm" role="alert"></p>
        </div>

        <div class="grid gap-2 md:grid-cols-2">
          <div class="grid gap-2">
            <label class="text-theme text-sm font-semibold" for="name">
              {t("contribute.form.name.label")}
            </label>
            <input
              id="name"
              name="name"
              type="text"
              maxlength="120"
              autocomplete="name"
              aria-describedby="nameError"
              class="border-theme bg-accent text-theme focus:border-primary rounded-lg border px-3 py-2.5 transition-colors focus:outline-hidden"
              placeholder={t("contribute.form.name.placeholder")}
            />
            <p id="nameError" class="text-error m-0 hidden text-sm" role="alert"></p>
          </div>

          <div class="grid gap-2">
            <label class="text-theme text-sm font-semibold" for="email">
              {t("contribute.form.email.label")}
            </label>
            <input
              id="email"
              name="email"
              type="email"
              maxlength="254"
              autocomplete="email"
              aria-describedby="emailError"
              class="border-theme bg-accent text-theme focus:border-primary rounded-lg border px-3 py-2.5 transition-colors focus:outline-hidden"
              placeholder={t("contribute.form.email.placeholder")}
            />
            <p id="emailError" class="text-error m-0 hidden text-sm" role="alert"></p>
          </div>
        </div>
        <p class="text-secondary m-0 inline-flex items-start gap-2 text-sm">
          <Info size={14} class="mt-0.5 shrink-0" aria-hidden="true" />
          <span>{t("contribute.form.contact.hint")}</span>
        </p>

        <div class="mt-2 flex flex-wrap items-center gap-3" data-state="idle" id="contributeFooter">
          <button
            id="contributeSubmit"
            type="submit"
            class="badge-primary-gradient hover:shadow-theme-lg inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white! transition-all duration-200 hover:-translate-y-0.5 hover:text-white! focus-visible:text-white! active:scale-95"
          >
            <Send id="contributeSubmitIcon" size={14} aria-hidden="true" />
            <span id="contributeSpinner" class="spinner hidden" aria-hidden="true"></span>
            <span id="contributeSubmitLabel">{t("contribute.form.submit")}</span>
          </button>
          <p id="contributeStatus" class="text-sm" data-state="idle" aria-live="polite"></p>
        </div>
      </form>

      <div
        id="contributeSuccess"
        class="bg-success-soft border-theme hidden rounded-2xl border p-6 md:p-8"
        role="status"
        aria-live="polite"
      >
        <div
          class="bg-success mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full text-white"
          aria-hidden="true"
        >
          <Check size={24} />
        </div>
        <h2 class="m-0 mb-2 text-center text-2xl">
          {t("contribute.form.success.heading")}
        </h2>
        <p
          id="contributeSuccessBody"
          class="text-secondary m-0 mb-6 text-center text-base leading-relaxed"
        >
          <!-- filled by JS with the submitted word -->
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <button
            id="contributeAnother"
            type="button"
            class="badge-primary-gradient hover:shadow-theme-lg inline-flex shrink-0 cursor-pointer items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-semibold text-white! transition-all duration-200 hover:-translate-y-0.5 hover:text-white! focus-visible:text-white! active:scale-95"
          >
            <Plus size={14} aria-hidden="true" />
            <span>{t("contribute.form.success.cta.another")}</span>
          </button>
          <a
            href={`${prefix}/`}
            class="border-theme bg-card text-theme hover:border-primary hover:bg-card-hover focus-visible:outline-primary inline-flex shrink-0 items-center gap-2 rounded-lg border px-4 py-2.5 text-sm font-semibold transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 active:scale-95"
          >
            <BookOpen size={14} aria-hidden="true" />
            <span>{t("contribute.form.success.cta.browse")}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script
    is:inline
    define:vars={{
      sendingText: t("contribute.form.sending"),
      successText: t("contribute.form.success"),
      errorText: t("contribute.form.error"),
      successHeadingText: t("contribute.form.success.heading"),
      successBodyText: t("contribute.form.success.body"),
      wordRequiredText: t("contribute.form.validation.wordRequired"),
      emailInvalidText: t("contribute.form.validation.emailInvalid"),
      tooLongText: t("contribute.form.validation.tooLong"),
      fixFieldsText: t("contribute.form.validation.fixFields"),
      successCtaAnotherText: t("contribute.form.success.cta.another"),
      successCtaBrowseText: t("contribute.form.success.cta.browse"),
    }}
  >
    const initContributeForm = () => {
      const form = document.getElementById("contributeForm");
      const status = document.getElementById("contributeStatus");
      const footer = document.getElementById("contributeFooter");
      const submit = document.getElementById("contributeSubmit");
      const submitLabel = document.getElementById("contributeSubmitLabel");
      const submitIcon = document.getElementById("contributeSubmitIcon");
      const spinner = document.getElementById("contributeSpinner");
      const wordInput = document.getElementById("word");
      const successCard = document.getElementById("contributeSuccess");
      const successBody = document.getElementById("contributeSuccessBody");
      const anotherBtn = document.getElementById("contributeAnother");

      if (
        !form ||
        !status ||
        !footer ||
        !submit ||
        !submitLabel ||
        !successCard ||
        !successBody ||
        form.dataset.bound === "1"
      ) {
        return;
      }

      const fields = Array.from(
        form.querySelectorAll("input:not([type='hidden']), textarea")
      ).filter(
        (field) => field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement
      );
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      const setStatus = (message, state) => {
        status.textContent = message || "";
        status.dataset.state = state || "idle";
      };

      const setFieldError = (field, message) => {
        const errorElement = document.getElementById(`${field.id}Error`);
        if (!(errorElement instanceof HTMLParagraphElement)) {
          return;
        }

        field.setAttribute("aria-invalid", "true");
        field.classList.add("border-error", "focus:border-error");
        field.classList.remove("border-theme", "focus:border-primary");

        errorElement.textContent = message;
        errorElement.classList.remove("hidden");
      };

      const clearFieldError = (field) => {
        const errorElement = document.getElementById(`${field.id}Error`);
        if (!(errorElement instanceof HTMLParagraphElement)) {
          return;
        }

        field.removeAttribute("aria-invalid");
        field.classList.remove("border-error", "focus:border-error");
        field.classList.add("border-theme", "focus:border-primary");

        errorElement.textContent = "";
        errorElement.classList.add("hidden");
      };

      const getFieldErrorMessage = (field) => {
        const value = field.value;

        if (field.id === "word" && !value.trim()) {
          return wordRequiredText;
        }

        if (field.validity.tooLong) {
          return tooLongText;
        }

        if (field.id === "email") {
          const emailValue = value.trim();
          if (emailValue && !emailPattern.test(emailValue)) {
            return emailInvalidText;
          }
        }

        if (
          field.validity.typeMismatch &&
          field instanceof HTMLInputElement &&
          field.type === "email"
        ) {
          return emailInvalidText;
        }

        return "";
      };

      const validateField = (field) => {
        const message = getFieldErrorMessage(field);
        if (message) {
          setFieldError(field, message);
          return false;
        }

        clearFieldError(field);
        return true;
      };

      const validateForm = () => {
        let firstInvalidField = null;

        for (const field of fields) {
          const isValid = validateField(field);
          if (!isValid && !firstInvalidField) {
            firstInvalidField = field;
          }
        }

        return {
          valid: !firstInvalidField,
          firstInvalidField,
        };
      };

      const counters = {
        word: document.getElementById("wordCount"),
        meaning: document.getElementById("meaningCount"),
        examples: document.getElementById("examplesCount"),
      };

      const updateCounter = (field) => {
        const counter = counters[field.id];
        if (!counter) return;
        const max = field.getAttribute("maxlength") || "0";
        const length = field.value.length;
        const ratio = length / Number(max);
        counter.textContent = `${length}/${max}`;
        counter.classList.remove("text-error");
        if (ratio >= 1) {
          counter.classList.add("text-error");
        }
      };

      for (const field of fields) {
        field.addEventListener("input", () => {
          validateField(field);
          updateCounter(field);
          if (status.dataset.state === "error") {
            setStatus("", "idle");
          }
        });
        field.addEventListener("blur", () => {
          validateField(field);
        });
        updateCounter(field);
      }

      if (wordInput instanceof HTMLInputElement) {
        const params = new URLSearchParams(window.location.search);
        const prefilledWord = params.get("word")?.trim();
        if (prefilledWord && !wordInput.value.trim()) {
          wordInput.value = prefilledWord;
          updateCounter(wordInput);
        }
      }

      const setSubmitting = (isSubmitting) => {
        if (isSubmitting) {
          submit.disabled = true;
          submit.setAttribute("aria-busy", "true");
          footer.dataset.state = "submitting";
          submitIcon?.classList.add("hidden");
          spinner?.classList.remove("hidden");
          submitLabel.textContent = sendingText;
        } else {
          submit.disabled = false;
          submit.removeAttribute("aria-busy");
          footer.dataset.state = footer.dataset.state === "success" ? "success" : "idle";
          submitIcon?.classList.remove("hidden");
          spinner?.classList.add("hidden");
          submitLabel.textContent = form.dataset.submitText || successCtaAnotherText;
        }
      };

      const showSuccess = (submittedWord) => {
        const safeWord = (submittedWord || "").replace(/[<>]/g, "");
        successBody.textContent = successBodyText.replace("{word}", safeWord);
        form.classList.add("hidden");
        successCard.classList.remove("hidden");
        footer.dataset.state = "success";
        setStatus("", "idle");
        successCard.scrollIntoView({ behavior: "smooth", block: "nearest" });
      };

      const showForm = () => {
        successCard.classList.add("hidden");
        form.classList.remove("hidden");
        footer.dataset.state = "idle";
        form.reset();
        for (const field of fields) {
          clearFieldError(field);
          updateCounter(field);
        }
        wordInput?.focus();
      };

      anotherBtn?.addEventListener("click", showForm);

      form.addEventListener("keydown", (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === "Enter") {
          event.preventDefault();
          if (!submit.disabled) {
            form.requestSubmit();
          }
        }
      });

      form.dataset.bound = "1";
      form.dataset.submitText = submitLabel.textContent || "";

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const validation = validateForm();
        if (!validation.valid) {
          setStatus(fixFieldsText, "error");
          validation.firstInvalidField?.focus();
          return;
        }

        const formData = new FormData(form);
        const payload = {
          word: String(formData.get("word") || "").trim(),
          meaning: String(formData.get("meaning") || "").trim(),
          examples: String(formData.get("examples") || "").trim(),
          name: String(formData.get("name") || "").trim(),
          email: String(formData.get("email") || "").trim(),
          company: String(formData.get("company") || "").trim(),
        };

        setSubmitting(true);

        try {
          const response = await fetch("/api/contribute/", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            throw new Error("Request failed");
          }

          showSuccess(payload.word);
        } catch {
          setStatus(errorText, "error");
          footer.dataset.state = "error";
        } finally {
          setSubmitting(false);
          // Restore the standard label, not the success state
          submitLabel.textContent = form.dataset.submitText || "";
        }
      });
    };

    initContributeForm();
    document.addEventListener("astro:page-load", initContributeForm);
  </script>
</Base>
